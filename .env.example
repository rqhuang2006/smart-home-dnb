# Smart Home DnB local environment example
# Copy this file to .env for your own machine. Do not commit .env.

# IoT simulator mode:
# api = send generated data to FastAPI backend /api/v1/iot/telemetry
# db  = write generated data directly into MySQL tables
IOT_SIM_TARGET=api
IOT_API_URL=http://127.0.0.1:8000/api/v1/iot/telemetry
IOT_SIM_INTERVAL_SECONDS=30

# MySQL mode settings, only used when IOT_SIM_TARGET=db
IOT_DB_HOST=localhost
IOT_DB_PORT=3307
IOT_DB_USER=root
IOT_DB_PASSWORD=change-me
IOT_DB_NAME=iot_smart_system

# Service ports
BACKEND_PORT=8000
FACE_PORT=8001
YOLO_PORT=5000
